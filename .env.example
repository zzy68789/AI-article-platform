# ========================================
# AI 爆款文章创作器 - 环境变量配置
# ========================================
# 复制此文件为 .env 并填写相应的配置值
# cp .env.example .env

# ============ 必需配置 ============

# 通义千问 API Key（必需）
# 获取地址：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key

# Pexels 图片 API Key（必需）
# 获取地址：https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key

# ============ 数据库配置 ============

# MySQL 配置
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=ai_passage_creator
MYSQL_USER=root
# MySQL 外部访问端口（默认不暴露，如需暴露请在 docker-compose.yml 中取消注释）
MYSQL_PORT=13306

# Redis 配置
# Redis 外部访问端口（默认不暴露，如需暴露请在 docker-compose.yml 中取消注释）
REDIS_PORT=16379
REDIS_PASSWORD=

# ============ 服务端口配置 ============

# 后端服务端口（Spring Boot）
BACKEND_PORT=8123

# 前端服务端口（Nginx）
FRONTEND_PORT=80

# ============ 时区配置 ============

TZ=Asia/Shanghai

# ============ JVM 配置 ============

JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC

# ============ 可选配置 ============

# Nano Banana API Key（AI 图片生成，可选）
# NANO_BANANA_API_KEY=

# Stripe 支付配置（VIP 功能，可选）
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_SUCCESS_URL=http://localhost/vip?success=true
# STRIPE_CANCEL_URL=http://localhost/vip?cancelled=true

# 微信公众号发布配置（可选，启用一键发布时必填）
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=
# WECHAT_DEFAULT_AUTHOR=
# WECHAT_BASE_URL=https://api.weixin.qq.com/cgi-bin
# WECHAT_CONNECT_TIMEOUT_MS=10000
# WECHAT_READ_TIMEOUT_MS=30000

# 微信开放平台第三方平台配置（允许其他用户扫码授权自己的公众号）
# WECHAT_OPEN_PLATFORM_ENABLED=false
# WECHAT_COMPONENT_APP_ID=
# WECHAT_COMPONENT_APP_SECRET=
# WECHAT_COMPONENT_TOKEN=
# WECHAT_COMPONENT_AES_KEY=
# WECHAT_AUTHORIZATION_REDIRECT_URI=https://your-domain.com/api/wechat/open-platform/authorization/callback
# WECHAT_FRONTEND_SUCCESS_URL=https://your-domain.com/wechat/accounts
# 使用 16/24/32 字节随机值 Base64 编码，生产环境必须固定保存，丢失后无法解密已授权账号
# WECHAT_CREDENTIAL_ENCRYPTION_KEY=

# 腾讯云 COS 配置（对象存储，可选）
# TENCENT_COS_SECRET_ID=
# TENCENT_COS_SECRET_KEY=
# TENCENT_COS_REGION=ap-guangzhou
# TENCENT_COS_BUCKET=
